generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Quote {
  id          String   @id @default(uuid())
  classType   String
  cargoType   String
  cargoValue  Float
  origin      String
  destination String
  status      QuoteStatus @default(PENDING)
  premium     Float
  createdAt   DateTime @default(now())
  policies    Policy[]

  @@index([createdAt])
}

model Policy {
  id           String   @id @default(uuid())
  policyNumber String   @unique
  quoteId      String
  quote        Quote    @relation(fields: [quoteId], references: [id])
  customerName String
  status       String
  createdAt    DateTime @default(now())

  @@index([quoteId])
}

model User {
  Id      String    @id @default(uuid())
  username  String  @unique
  email     String? 
  password  String
  role      Role
  rate      Float
  wallet    Float     @default(0)
  createdAt DateTime  @default(now())
  TR
}

enum Role{
  ADMIN
  STAFF
  USER
}

enum QuoteStatus{
  PENDING 
  APPROVED 
  REJECTED
}

model WalletTransaction{
  id      String @id @default(uuid())
  userId  String
  userId  User    @relation(fields:[userId], references: [id])
  amount  Float
  type    TransactionType
  description String
  createdAt  DateTime @default(now())
}

enum TransactionType{
  CREDIT
  DEBIT
}