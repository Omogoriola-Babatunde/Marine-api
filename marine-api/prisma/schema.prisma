generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Quote {
  id          String      @id @default(uuid())
  classType   String
  cargoType   String
  cargoValue  Float
  origin      String
  destination String
  status      QuoteStatus
  premium     Float
  createdAt   DateTime    @default(now())
  policies    Policy[]
  createdById String
  createdBy   User        @relation(fields: [createdById], references: [id])

  @@index([createdAt])
}

model Policy {
  id              String    @id @default(uuid())
  policyNumber    String    @unique
  quoteId         String
  quote           Quote     @relation(fields: [quoteId], references: [id])
  customerName    String
  proformaInvoice String?
  mode            String?
  currency        String?
  invoiceValue    Float?
  exchangeRate    Float?
  startDate       DateTime?
  endDate         DateTime?
  naicomId        String?
  status          String
  createdAt       DateTime  @default(now())
  issuedById      String
  issuedBy        User      @relation(fields: [issuedById], references: [id])

  @@index([quoteId])
}

model User {
  id           String              @id @default(uuid())
  fullName     String
  email        String              @unique
  password     String
  role         Role
  classARate   Float               @default(0)
  classBRate   Float               @default(0)
  wallet       Float               @default(0)
  createdAt    DateTime            @default(now())
  quotes       Quote[]
  policies     Policy[]
  transactions WalletTransaction[]
  AuditLog     AuditLog[]
}

enum Role {
  ADMIN
  STAFF
  USER
}

enum PolicyStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

model WalletTransaction {
  id          String          @id @default(uuid())
  userId      String
  user        User            @relation(fields: [userId], references: [id])
  amount      Float
  type        TransactionType
  description String
  createdAt   DateTime        @default(now())
}

enum TransactionType {
  CREDIT
  DEBIT
}

model AuditLog{
  id String @id @default(uuid())
  userId String 
  user User @relation(fields: [userId], references: [id])
  action String 
  description String 
  createdAt DateTime @default(now())
}


enum QuoteStatus {
  GENERATED
  CONVERTED
  EXPIRED
}
