# Required.
# Postgres connection string. Example local DB:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marine_api

# HTTP port. Default 4000 to leave port 3000 free for a Next.js frontend.
PORT=4000

# Comma-separated CORS origins. Defaults cover common frontend dev ports
# (Vite 5173, Next.js 3000). Adjust if your frontend runs elsewhere.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Where generated certificate PDFs are stored. Default: ./certificates
# CERTIFICATE_DIR=./certificates

# Set to "production" to enable production-only checks (e.g. CORS warning).
# NODE_ENV=development
