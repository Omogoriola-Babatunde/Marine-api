# Required.
# Postgres connection string. Example local DB:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/marine_api

# HTTP port (default: 3000)
# PORT=3000

# Comma-separated CORS origins. Default: http://localhost:3000
# ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Where generated certificate PDFs are stored. Default: ./certificates
# CERTIFICATE_DIR=./certificates

# Set to "production" to enable production-only checks (e.g. CORS warning).
# NODE_ENV=development
