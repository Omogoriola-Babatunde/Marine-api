{
  "name": "marine-api",
  "version": "1.0.0",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "prisma migrate deploy && node server.js",
    "dev": "node --watch server.js",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "postinstall": "prisma generate"
  },
  "engines": {
    "node": ">=22.12"
  },
  "packageManager": "pnpm@10.32.1",
